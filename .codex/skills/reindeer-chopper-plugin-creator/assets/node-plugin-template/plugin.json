{
  "id": "__PLUGIN_ID__",
  "name": "__PLUGIN_NAME__",
  "version": "1.0.0",
  "description": "__PLUGIN_DESCRIPTION__",
  "runtime": {
    "windows": {
      "run": "node index.js",
      "install": "npm install"
    },
    "mac": {
      "run": "node index.js",
      "install": "npm install"
    }
  },
  "parameters": [
    {
      "name": "message",
      "label": "Message",
      "type": "text",
      "required": true,
      "default": "Hello from __PLUGIN_NAME__"
    },
    {
      "name": "count",
      "label": "Repeat Count",
      "type": "number",
      "default": 1
    },
    {
      "name": "mode",
      "label": "Output Mode",
      "type": "select",
      "default": "greet",
      "options": ["greet", "intro"],
      "description": "Choose greeting mode or intro mode."
    },
    {
      "name": "loud",
      "label": "Loud Mode",
      "type": "boolean",
      "default": false
    },
    {
      "name": "inputFile",
      "label": "Input File",
      "type": "filepath",
      "pathMode": "file",
      "description": "Optional input file path."
    },
    {
      "name": "outputDir",
      "label": "Output Directory",
      "type": "filepath",
      "pathMode": "directory",
      "description": "Optional output directory path."
    }
  ]
}
